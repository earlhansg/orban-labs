# URL Shortener Service Configuration

# Database
DATABASE_URL=sqlite:///./url_shortener.db

# Authentication
API_KEY=your-secret-api-key-here

# URL shortening settings
SHORT_CODE_LENGTH=6
MAX_SHORT_CODE_LENGTH=8
MAX_COLLISION_RETRIES=5

# URL validation
MAX_URL_LENGTH=2048
ALLOWED_SCHEMES=["http", "https"]

# Application
APP_NAME=URL Shortener Service
APP_VERSION=1.0.0
DEBUG=false

# CORS
ALLOWED_ORIGINS=["*"]